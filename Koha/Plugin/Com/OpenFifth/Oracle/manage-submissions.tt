[% USE raw %]
[% USE Asset %]
[% USE KohaDates %]
[% PROCESS 'i18n.inc' %]
[% SET footerjs = 1 %]
[% INCLUDE 'doc-head-open.inc' %]
<title>[% FILTER collapse %]
    [% t("Submitted Invoices") | html %] &rsaquo;
    [% t("RBKC Oracle") | html %] &rsaquo;
    [% t("Plugins") | html %] &rsaquo;
    [% t("Koha") | html %]
[% END %]</title>
[% INCLUDE 'doc-head-close.inc' %]
</head>
<body id="plugins_rbkc_oracle" class="plugins">
[% WRAPPER 'header.inc' %]
    [% INCLUDE 'cat-search.inc' %]
[% END %]

[% WRAPPER 'sub-header.inc' %]
    [% WRAPPER breadcrumbs %]
        [% WRAPPER breadcrumb_item %]
            <a href="/cgi-bin/koha/tools/tools-home.pl">Tools</a>
        [% END %]
        [% WRAPPER breadcrumb_item bc_active= 1 %]
            <span>RBKC Oracle &mdash; Submitted Invoices</span>
        [% END %]
    [% END #/ WRAPPER breadcrumbs %]
[% END #/ WRAPPER sub-header.inc %]

<div id="main container-fluid">
    <div class="row">
        <div class="col-md-10 order-md-2 order-sm-1">
            <main>
                <h1>RBKC Oracle &mdash; Tools</h1>

                <div class="page-section">
                    <h2>Recent cron runs</h2>
                    [% IF cron_runs.size %]
                    <p>The 30 most recent nightly cron executions. <strong>success</strong> means a file was generated and delivered; <strong>no_data</strong> means the cron ran but found no invoices for the date range; <strong>error</strong> means delivery failed.</p>
                    <table class="table table-bordered table-sm">
                        <thead>
                            <tr>
                                <th>Run at</th>
                                <th>Status</th>
                                <th>Invoices</th>
                                <th>Filename</th>
                                <th>Detail</th>
                            </tr>
                        </thead>
                        <tbody>
                            [% FOREACH run IN cron_runs %]
                            <tr>
                                <td>[% run.run_at | html %]</td>
                                <td>
                                    [% IF run.status == 'success' %]<span class="badge badge-success">[% run.status | html %]</span>
                                    [% ELSIF run.status == 'no_data' %]<span class="badge badge-secondary">[% run.status | html %]</span>
                                    [% ELSIF run.status == 'error' %]<span class="badge badge-danger">[% run.status | html %]</span>
                                    [% ELSE %]<span class="badge badge-info">[% run.status | html %]</span>
                                    [% END %]
                                </td>
                                <td>[% run.invoices_found | html %]</td>
                                <td>[% run.filename | html %]</td>
                                <td>[% run.message | html %]</td>
                            </tr>
                            [% END %]
                        </tbody>
                    </table>
                    [% ELSE %]
                    <div class="alert alert-info">
                        No nightly cron runs have been recorded yet.
                    </div>
                    [% END %]
                </div>

                <h2>Submitted Invoices</h2>
                <div class="page-section">
                    [% IF submitted_invoices.size %]
                    <p>The following invoices have been successfully submitted to Oracle. Select invoices and click <strong>Allow resubmission</strong> to remove them from the submitted list.</p>
                    <form method="get" action="/cgi-bin/koha/plugins/run.pl">
                        <input type="hidden" name="class" value="[% CLASS | html %]"/>
                        <input type="hidden" name="method" value="tool"/>
                        <input type="hidden" name="action" value="clear"/>
                        <table class="table table-bordered table-sm">
                            <thead>
                                <tr>
                                    <th><input type="checkbox" id="select-all" title="Select all"/></th>
                                    <th>Invoice Number</th>
                                    <th>Submitted At</th>
                                    <th>Submitted By</th>
                                    <th>Filename</th>
                                </tr>
                            </thead>
                            <tbody>
                                [% FOREACH inv IN submitted_invoices %]
                                <tr>
                                    <td><input type="checkbox" name="invoicenumber" value="[% inv.invoicenumber | html %]"/></td>
                                    <td>[% inv.invoicenumber | html %]</td>
                                    <td>[% inv.submitted_at | html %]</td>
                                    <td>[% inv.submitted_by | html %]</td>
                                    <td>[% inv.filename | html %]</td>
                                </tr>
                                [% END %]
                            </tbody>
                        </table>
                        <fieldset class="action">
                            <input type="submit" class="btn btn-warning" value="Allow resubmission"/>
                        </fieldset>
                    </form>
                    [% ELSE %]
                    <div class="alert alert-info">
                        No invoices have been submitted yet.
                    </div>
                    [% END %]
                </div>
            </main>
        </div>
        <div class="col-md-2 order-sm-2 order-md-1">
            <aside></aside>
        </div>
    </div>

[% MACRO jsinclude BLOCK %]
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var selectAll = document.getElementById('select-all');
            if (!selectAll) return;
            selectAll.addEventListener('change', function () {
                var checked = selectAll.checked;
                document.querySelectorAll('input[name="invoicenumber"]').forEach(function (cb) {
                    cb.checked = checked;
                });
            });
        });
    </script>
[% END %]

[% INCLUDE 'intranet-bottom.inc' %]
